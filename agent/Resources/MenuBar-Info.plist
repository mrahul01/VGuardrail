<?xml version="1.0" encoding="UTF-8"?>
<!-- Info.plist for the menu bar app bundle. LSUIElement makes it an accessory
     (menu-bar-only, no Dock icon). Merge into the .app bundle at packaging time. -->
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>CFBundleIdentifier</key>
    <string>com.vguardrail.menubar</string>
    <key>CFBundleName</key>
    <string>VGuardrail</string>
    <key>CFBundleShortVersionString</key>
    <string>0.1.0</string>
    <key>LSUIElement</key>
    <true/>
    <key>LSMinimumSystemVersion</key>
    <string>14.0</string>
</dict>
</plist>
