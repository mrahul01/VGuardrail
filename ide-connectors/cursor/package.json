{
  "name": "vguardrail-cursor",
  "displayName": "VGuardrail for Cursor",
  "description": "VGuardrail connector for the Cursor IDE MVP.",
  "version": "0.1.0",
  "engines": {
    "vscode": "^1.90.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "vguardrail.status",
        "title": "VGuardrail: Show Status"
      }
    ]
  },
  "scripts": {
    "vscode:prepublish": "npm run package",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "package": "esbuild ./src/extension.ts --bundle --outfile=dist/extension.js --external:vscode --format=cjs --platform=node",
    "lint": "eslint src --ext ts"
  },
  "dependencies": {
    "@vguardrail/connector-sdk": "file:../../connector-sdk"
  },
  "devDependencies": {
    "@types/vscode": "^1.90.0",
    "@types/node": "20.x",
    "typescript": "^5.5.0",
    "esbuild": "^0.23.0"
  }
}
