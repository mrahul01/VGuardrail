# VGuardrail — Docker environment template.
#
# Copy to `.env` and fill in real values. `.env` is git-ignored.
#
# `docker compose up` will pick this up automatically.

# ── AWS credentials (the backend uses the default SDK chain) ────────────────
AWS_REGION=us-east-1
# AWS_ACCESS_KEY_ID=...
# AWS_SECRET_ACCESS_KEY=...
# AWS_SESSION_TOKEN=...   # only for STS-assumed roles

# ── Resource names (set by Terraform) ───────────────────────────────────────
VG_CORE_TABLE=vguardrail-core-dev
VG_AUDIT_TABLE=vguardrail-audit-dev
VG_AUDIT_BUCKET=vguardrail-audit-archive-dev
VG_USER_POOL_ID=us-east-1_xxxxxxxxx
VG_APP_CLIENT_ID=xxxxxxxxxxxxxxxxxxxxxxxxxx
VG_ENROLLMENT_PREFIX=vguardrail/enrollment/
# Base64 Ed25519 pubkey used to verify served policy bundles.
VG_POLICY_PUBKEY=
# Issuer override (otherwise derived from user-pool id). Region-prefixed.
VG_COGNITO_ISSUER=https://cognito-idp.us-east-1.amazonaws.com/us-east-1_xxxxxxxxx

# ── Server tunables ─────────────────────────────────────────────────────────
RUST_LOG=info,server=debug,tower_http=info
REQUEST_TIMEOUT_S=30
MAX_BODY_BYTES=6291456

# ── Dashboard Cognito Hosted-UI auth ────────────────────────────────────────
# All read by the dashboard auth layer (lib/auth/cognito-client.ts + jwt.ts).
# Values come from `terraform output` of the cognito module.
#   NEXT_PUBLIC_COGNITO_DOMAIN  = <cognito_domain>.auth.<region>.amazoncognito.com
#   NEXT_PUBLIC_COGNITO_CLIENT_ID = the DASHBOARD app client id (not the device client)
#   COGNITO_ISSUER              = https://cognito-idp.<region>.amazonaws.com/<user_pool_id>
#   COGNITO_CLIENT_SECRET       = the dashboard app client secret (confidential)
#   COGNITO_REDIRECT_URI        = <app_url>/api/auth/callback/cognito (must be registered on the client)
NEXT_PUBLIC_COGNITO_DOMAIN=vguardrail-dev-xxxxxxxxxxxx.auth.us-east-1.amazoncognito.com
NEXT_PUBLIC_COGNITO_CLIENT_ID=xxxxxxxxxxxxxxxxxxxxxxxxxx
NEXT_PUBLIC_APP_URL=http://localhost:3000
COGNITO_ISSUER=https://cognito-idp.us-east-1.amazonaws.com/us-east-1_xxxxxxxxx
COGNITO_REDIRECT_URI=http://localhost:3000/api/auth/callback/cognito
COGNITO_CLIENT_SECRET=replace-with-dashboard-client-secret

# ── Local development only ────────────────────────────────────────────────
# Set to 1 to bypass JWT verification and accept x-vg-* headers.
# MUST be 0 (or unset) in any deployed environment.
VG_DEV_CLAIMS=1

# Dashboard app client id — accepted as an additional backend JWT audience.
VG_DASHBOARD_CLIENT_ID=xxxxxxxxxxxxxxxxxxxxxxxxxx
